@{
    ViewData["Title"] = "Our Services";
}

<style>
    .service-nav {
        position: sticky;
        top: 0;
        z-index: 100;
        background: white;
        box-shadow: 0 2px 10px rgba(107, 46, 62, 0.1);
    }

        .service-nav a {
            color: #6B2E3E;
            font-weight: 600;
            transition: all 0.3s ease;
            text-decoration: none;
        }

            .service-nav a:hover {
                color: #C9A961;
            }

    .section-anchor {
        scroll-margin-top: 100px;
    }
</style>

<!-- Page Header -->
<section class="page-header bg-primary text-white py-5">
    <div class="container text-center py-4">
        <h1 class="display-4 fw-bold mb-3">Our Services</h1>
        <p class="lead">Comprehensive digital solutions tailored for small businesses</p>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb justify-content-center bg-transparent mb-0">
                <li class="breadcrumb-item"><a href="/" class="text-white">Home</a></li>
                <li class="breadcrumb-item text-white-50 active">Services</li>
            </ol>
        </nav>
    </div>
</section>

<!-- Quick Navigation -->
<div class="service-nav py-3">
    <div class="container">
        <div class="d-flex justify-content-center gap-4 flex-wrap">
            <a href="#website-development">
                <i class="fas fa-laptop-code me-2"></i>Website Development
            </a>
            <a href="#ecommerce-setup">
                <i class="fas fa-store me-2"></i>E-commerce Setup
            </a>
            <a href="#brand-identity">
                <i class="fas fa-palette me-2"></i>Brand Identity
            </a>
            <a href="#seo-optimization">
                <i class="fas fa-search me-2"></i>SEO Optimization
            </a>
        </div>
    </div>
</div>

<!-- Services Overview -->
