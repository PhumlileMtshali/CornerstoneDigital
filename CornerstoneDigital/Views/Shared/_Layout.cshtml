<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Cornerstone Digital</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary sticky-top">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" asp-controller="Home" asp-action="Index">
                <img src="~/Images/Logo.jpeg" alt="Cornerstone Digital Logo" class="navbar-logo me-3" style="height: 80px; width: auto; border-radius: 8px;">
                <div class="d-flex flex-column">
                    <span class="brand-name fw-bold">CORNERSTONE</span>
                    <span class="brand-tagline fw-light">DIGITAL</span>
                </div>
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Services" asp-action="Index">Services</a>
                    </li>
                    
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="About">About</a>
                    </li>
                    
                    <partial name="_LoginPartial" />
                    <li class="nav-item ms-lg-3">
                        <a class="btn btn-light btn-sm" asp-controller="Home" asp-action="Quote">Get a Quote</a>
                    </li>
                </ul>
                
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main role="main">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="bg-dark text-white py-5 mt-5">
        <div class="container">
            <div class="row">
                <div class="col-md-4 mb-4">
                    <h5 class="fw-bold mb-3">
                        <i class="fas fa-layer-group me-2"></i>
                        Cornerstone Digital
                    </h5>
                    <p class="text-light">Building your digital foundation with professional web solutions for small businesses.</p>
                    <div class="social-links mt-3">
                        <a href="#" class="text-white me-3"><i class="fab fa-linkedin fa-lg"></i></a>
                        <a href="#" class="text-white me-3"><i class="fab fa-twitter fa-lg"></i></a>
                        <a href="#" class="text-white me-3"><i class="fab fa-facebook fa-lg"></i></a>
                        <a href="#" class="text-white"><i class="fab fa-instagram fa-lg"></i></a>
                    </div>
                </div>

                <div class="col-md-2 mb-4">
                    <h6 class="fw-bold mb-3">Services</h6>
                    <ul class="list-unstyled">
                        <li><a href="#" class="text-light text-decoration-none">Web Development</a></li>
                        <li><a href="#" class="text-light text-decoration-none">E-commerce</a></li>
                        <li><a href="#" class="text-light text-decoration-none">Brand Identity</a></li>
                        <li><a href="#" class="text-light text-decoration-none">SEO</a></li>
                    </ul>
                </div>

                <div class="col-md-3 mb-4">
                    <h6 class="fw-bold mb-3">Company</h6>
                    <ul class="list-unstyled">
                        <li><a class="text-light text-decoration-none" asp-controller="Home" asp-action="About">About Us</a></li>
                        <li><a class="text-light text-decoration-none" asp-controller="Home" asp-action="Portfolio">Portfolio</a></li>
                        <li><a class="text-light text-decoration-none" asp-controller="Home" asp-action="Testimonials">Testimonials</a></li>
                        <li><a class="text-light text-decoration-none" asp-controller="Home" asp-action="Contact">Contact</a></li>
                    </ul>
                </div>

                <div class="col-md-3 mb-4">
                    <h6 class="fw-bold mb-3">Contact Info</h6>
                    <ul class="list-unstyled text-light">
                        <li><i class="fas fa-envelope me-2"></i> hello@cornerstonedigital.com</li>
                        <li><i class="fas fa-phone me-2"></i> +27 79 318 4076</li>
                        <li><i class="fas fa-map-marker-alt me-2"></i> Johannesburg, South Africa</li>
                    </ul>
                </div>
            </div>

            <hr class="bg-light">

            <div class="row">
                <div class="col-md-6 text-center text-md-start">
                    <p class="mb-0">&copy; @DateTime.Now.Year Cornerstone Digital. All rights reserved.</p>
                </div>
                <div class="col-md-6 text-center text-md-end">
                    <a class="text-light text-decoration-none me-3" asp-controller="Home" asp-action="Privacy">Privacy Policy</a>
                    <a class="text-light text-decoration-none" asp-controller="Home" asp-action="Terms">Terms of Service</a>
                </div>
            </div>
        </div>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <!-- jQuery (optional, for additional functionality) -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <!-- Custom JS -->
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>