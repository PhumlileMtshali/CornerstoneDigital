@model CornerstoneDigital.Models.ServicePackage
@{
    ViewData["Title"] = "Create Package";
}

<style>
    .admin-sidebar {
        background: linear-gradient(135deg, #6B2E3E 0%, #4A1F2C 100%);
        min-height: 100vh;
        padding: 20px;
        position: fixed;
        width: 250px;
    }

        .admin-sidebar a {
            color: white;
            text-decoration: none;
            display: block;
            padding: 12px 15px;
            border-radius: 8px;
            margin-bottom: 5px;
            transition: all 0.3s ease;
        }

            .admin-sidebar a:hover, .admin-sidebar a.active {
                background: rgba(201, 169, 97, 0.3);
            }

    .admin-content {
        margin-left: 270px;
        padding: 30px;
    }
</style>

<div class="admin-sidebar">
    <div class="text-center mb-4">
        <h4 class="text-white fw-bold">CORNERSTONE</h4>
        <p class="text-white-50 small">Admin Panel</p>
    </div>
    <a href="/Admin"><i class="fas fa-tachometer-alt me-2"></i> Dashboard</a>
    <a href="/Admin/Projects"><i class="fas fa-project-diagram me-2"></i> Projects</a>
    <a href="/Admin/Packages" class="active"><i class="fas fa-box me-2"></i> Service Packages</a>
    <a href="/Admin/Orders"><i class="fas fa-shopping-cart me-2"></i> Orders</a>
    <a href="/Admin/Testimonials"><i class="fas fa-star me-2"></i> Testimonials</a>
    <hr style="border-color: rgba(255,255,255,0.3);">
    <a href="/"><i class="fas fa-globe me-2"></i> View Website</a>
</div>

<div class="admin-content">
    <h2 class="fw-bold mb-4">Create New Package</h2>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
            <form asp-action="CreatePackage" method="post">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="ServiceType" class="form-label fw-bold">Service Type</label>
                        <select asp-for="ServiceType" class="form-select" required>
                            <option value="">Select Service</option>
                            <option value="website">Website Development</option>
                            <option value="ecommerce">E-commerce</option>
                            <option value="branding">Brand Identity</option>
                            <option value="seo">SEO Optimization</option>
                        </select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="PackageName" class="form-label fw-bold">Package Name</label>
                        <input asp-for="PackageName" class="form-control" placeholder="basic, standard, premium" required />
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Price" class="form-label fw-bold">Price ($)</label>
                        <input asp-for="Price" type="number" step="0.01" class="form-control" required />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="DeliveryTime" class="form-label fw-bold">Delivery Time</label>
                        <input asp-for="DeliveryTime" class="form-control" placeholder="e.g., 2-3 weeks" />
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label fw-bold">Description</label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                </div>

                <div class="mb-3">
                    <label asp-for="Features" class="form-label fw-bold">Features (JSON Array)</label>
                    <textarea asp-for="Features" class="form-control" rows="5" placeholder='["Feature 1", "Feature 2", "Feature 3"]'></textarea>
                    <small class="text-muted">Enter features as JSON array</small>
                </div>

                <div class="form-check mb-3">
                    <input asp-for="IsActive" class="form-check-input" type="checkbox" checked />
                    <label asp-for="IsActive" class="form-check-label">Active (show on website)</label>
                </div>

                <div class="form-check mb-4">
                    <input asp-for="IsFeatured" class="form-check-input" type="checkbox" />
                    <label asp-for="IsFeatured" class="form-check-label">Featured (mark as popular)</label>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save me-2"></i>Create Package
                    </button>
                    <a href="/Admin/Packages" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>