@model CornerstoneDigital.Models.Project
@{
    ViewData["Title"] = "Create Project";
}

<!-- Add same sidebar navigation -->
<div class="admin-content" style="margin-left: 270px; padding: 30px;">
    <h2 class="fw-bold mb-4">Create New Project</h2>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
            <form asp-action="CreateProject" method="post">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Title" class="form-label fw-bold"></label>
                        <input asp-for="Title" class="form-control" required />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Category" class="form-label fw-bold"></label>
                        <select asp-for="Category" class="form-select" required>
                            <option value="">Select Category</option>
                            <option value="Website">Website</option>
                            <option value="E-commerce">E-commerce</option>
                            <option value="Branding">Branding</option>
                            <option value="SEO">SEO</option>
                        </select>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Client" class="form-label fw-bold"></label>
                        <input asp-for="Client" class="form-control" required />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Duration" class="form-label fw-bold"></label>
                        <input asp-for="Duration" class="form-control" placeholder="e.g., 3 weeks" required />
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Challenge" class="form-label fw-bold"></label>
                    <textarea asp-for="Challenge" class="form-control" rows="3" required></textarea>
                </div>

                <div class="mb-3">
                    <label asp-for="Solution" class="form-label fw-bold"></label>
                    <textarea asp-for="Solution" class="form-control" rows="3" required></textarea>
                </div>

                <div class="mb-3">
                    <label asp-for="Results" class="form-label fw-bold"></label>
                    <textarea asp-for="Results" class="form-control" rows="3" placeholder='["Result 1", "Result 2", "Result 3"]'></textarea>
                    <small class="text-muted">Enter as JSON array</small>
                </div>

                <div class="mb-3">
                    <label asp-for="Technologies" class="form-label fw-bold"></label>
                    <textarea asp-for="Technologies" class="form-control" rows="2" placeholder='["Tech 1", "Tech 2"]'></textarea>
                    <small class="text-muted">Enter as JSON array</small>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="ImageIcon" class="form-label fw-bold"></label>
                        <input asp-for="ImageIcon" class="form-control" placeholder="laptop-code" required />
                        <small class="text-muted">Font Awesome icon name</small>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="SlugUrl" class="form-label fw-bold"></label>
                        <input asp-for="SlugUrl" class="form-control" placeholder="tech-startup" required />
                    </div>
                </div>

                <div class="form-check mb-4">
                    <input asp-for="IsActive" class="form-check-input" type="checkbox" checked />
                    <label asp-for="IsActive" class="form-check-label">Active (show on website)</label>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save me-2"></i>Create Project
                    </button>
                    <a href="/Admin/Projects" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>