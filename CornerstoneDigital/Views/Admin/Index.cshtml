@model dynamic
@{
    ViewData["Title"] = "Admin Dashboard";
}

<style>
    .admin-sidebar {
        background: linear-gradient(135deg, #6B2E3E 0%, #4A1F2C 100%);
        min-height: 100vh;
        padding: 20px;
        position: fixed;
        width: 250px;
    }

        .admin-sidebar a {
            color: white;
            text-decoration: none;
            display: block;
            padding: 12px 15px;
            border-radius: 8px;
            margin-bottom: 5px;
            transition: all 0.3s ease;
        }

            .admin-sidebar a:hover,
            .admin-sidebar a.active {
                background: rgba(201, 169, 97, 0.3);
            }

    .admin-content {
        margin-left: 270px;
        padding: 30px;
    }

    .stat-card {
        background: white;
        border-radius: 12px;
        padding: 25px;
        box-shadow: 0 5px 20px rgba(107, 46, 62, 0.1);
        border-left: 4px solid #C9A961;
    }

    .stat-icon {
        width: 60px;
        height: 60px;
        background: linear-gradient(135deg, #6B2E3E 0%, #4A1F2C 100%);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #C9A961;
    }
</style>

<!-- Sidebar -->
<div class="admin-sidebar">
    <div class="text-center mb-4">
        <h4 class="text-white fw-bold">CORNERSTONE</h4>
        <p class="text-white-50 small">Admin Panel</p>
    </div>

    <a href="/Admin" class="active">
        <i class="fas fa-tachometer-alt me-2"></i> Dashboard
    </a>
    <a href="/Admin/Projects">
        <i class="fas fa-project-diagram me-2"></i> Projects
    </a>
    <a href="/Admin/Packages">
        <i class="fas fa-box me-2"></i> Service Packages
    </a>
    <a href="/Admin/Orders">
        <i class="fas fa-shopping-cart me-2"></i> Orders
    </a>
    <a href="/Admin/Testimonials">
        <i class="fas fa-star me-2"></i> Testimonials
    </a>
    <hr style="border-color: rgba(255,255,255,0.3);">
    <a href="/">
        <i class="fas fa-globe me-2"></i> View Website
    </a>
    <a href="/Identity/Account/Logout">
        <i class="fas fa-sign-out-alt me-2"></i> Logout
    </a>
</div>

<!-- Main Content -->
<div class="admin-content">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">Dashboard Overview</h2>
            <p class="text-muted">Welcome back! Here's what's happening.</p>
        </div>
        <div class="text-muted">
            <i class="fas fa-calendar me-2"></i>@DateTime.Now.ToString("MMMM dd, yyyy")
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Stats Cards -->
    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="stat-card">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <p class="text-muted mb-1">Total Projects</p>
                        <h3 class="fw-bold mb-0">@Model.TotalProjects</h3>
                    </div>
                    <div class="stat-icon">
                        <i class="fas fa-project-diagram fa-2x"></i>
                    </div>
                </div>
                <small class="text-success">
                    <i class="fas fa-arrow-up me-1"></i>Active portfolio items
                </small>
            </div>
        </div>

        <div class="col-md-3">
            <div class="stat-card">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <p class="text-muted mb-1">Total Orders</p>
                        <h3 class="fw-bold mb-0">@Model.TotalOrders</h3>
                    </div>
                    <div class="stat-icon">
                        <i class="fas fa-shopping-cart fa-2x"></i>
                    </div>
                </div>
                <small class="text-warning">
                    <i class="fas fa-clock me-1"></i>@Model.PendingOrders pending
                </small>
            </div>
        </div>

        <div class="col-md-3">
            <div class="stat-card">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <p class="text-muted mb-1">Total Revenue</p>
                        <h3 class="fw-bold mb-0">$@Model.TotalRevenue.ToString("N0")</h3>
                    </div>
                    <div class="stat-icon">
                        <i class="fas fa-dollar-sign fa-2x"></i>
                    </div>
                </div>
                <small class="text-success">
                    <i class="fas fa-arrow-up me-1"></i>From paid orders
                </small>
            </div>
        </div>

        <div class="col-md-3">
            <div class="stat-card">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <p class="text-muted mb-1">Pending Orders</p>
                        <h3 class="fw-bold mb-0">@Model.PendingOrders</h3>
                    </div>
                    <div class="stat-icon">
                        <i class="fas fa-hourglass-half fa-2x"></i>
                    </div>
                </div>
                <small class="text-info">
                    <i class="fas fa-info-circle me-1"></i>Awaiting payment
                </small>
            </div>
        </div>
    </div>

    <!-- Recent Orders -->
    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="fw-bold mb-0">Recent Orders</h5>
                <a href="/Admin/Orders" class="btn btn-outline-primary btn-sm">View All</a>
            </div>

            @if (Model.RecentOrders.Count > 0)
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Order ID</th>
                                <th>Customer</th>
                                <th>Package</th>
                                <th>Amount</th>
                                <th>Status</th>
                                <th>Date</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model.RecentOrders)
                            {
                                <tr>
                                    <td><strong>@order.OrderReference</strong></td>
                                    <td>@order.CompanyName</td>
                                    <td>@order.ServiceType - @order.PackageName</td>
                                    <td><strong>$@order.Amount.ToString("N2")</strong></td>
                                    <td>
                                        @if (order.PaymentStatus == "Paid")
                                        {
                                            <span class="badge bg-success">Paid</span>
                                        }
                                        else if (order.PaymentStatus == "Pending")
                                        {
                                            <span class="badge bg-warning">Pending</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Failed</span>
                                        }
                                    </td>
                                    <td>@order.OrderDate.ToString("MMM dd, yyyy")</td>
                                    <td>
                                        <a href="/Admin/OrderDetails/@order.Id" class="btn btn-sm btn-outline-primary">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
                    <p class="text-muted">No orders yet</p>
                </div>
            }
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="row g-4 mt-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center p-4">
                    <i class="fas fa-plus-circle fa-3x text-primary mb-3"></i>
                    <h6 class="fw-bold mb-3">Add New Project</h6>
                    <a href="/Admin/CreateProject" class="btn btn-primary w-100">Create Project</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center p-4">
                    <i class="fas fa-box fa-3x text-primary mb-3"></i>
                    <h6 class="fw-bold mb-3">Add New Package</h6>
                    <a href="/Admin/CreatePackage" class="btn btn-primary w-100">Create Package</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center p-4">
                    <i class="fas fa-star fa-3x text-primary mb-3"></i>
                    <h6 class="fw-bold mb-3">Add Testimonial</h6>
                    <a href="/Admin/CreateTestimonial" class="btn btn-primary w-100">Create Testimonial</a>
                </div>
            </div>
        </div>
    </div>
</div>