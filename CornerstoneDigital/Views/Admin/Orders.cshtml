@model List<CornerstoneDigital.Models.Order>
@{
    ViewData["Title"] = "Manage Orders";
}

<style>
    .admin-sidebar {
        background: linear-gradient(135deg, #6B2E3E 0%, #4A1F2C 100%);
        min-height: 100vh;
        padding: 20px;
        position: fixed;
        width: 250px;
    }

        .admin-sidebar a {
            color: white;
            text-decoration: none;
            display: block;
            padding: 12px 15px;
            border-radius: 8px;
            margin-bottom: 5px;
        }

            .admin-sidebar a:hover, .admin-sidebar a.active {
                background: rgba(201, 169, 97, 0.3);
            }

    .admin-content {
        margin-left: 270px;
        padding: 30px;
    }
</style>

<div class="admin-sidebar">
    <div class="text-center mb-4">
        <h4 class="text-white fw-bold">CORNERSTONE</h4>
        <p class="text-white-50 small">Admin Panel</p>
    </div>
    <a href="/Admin"><i class="fas fa-tachometer-alt me-2"></i> Dashboard</a>
    <a href="/Admin/Projects"><i class="fas fa-project-diagram me-2"></i> Projects</a>
    <a href="/Admin/Packages"><i class="fas fa-box me-2"></i> Service Packages</a>
    <a href="/Admin/Orders" class="active"><i class="fas fa-shopping-cart me-2"></i> Orders</a>
    <a href="/Admin/Testimonials"><i class="fas fa-star me-2"></i> Testimonials</a>
    <hr style="border-color: rgba(255,255,255,0.3);">
    <a href="/"><i class="fas fa-globe me-2"></i> View Website</a>
</div>

<div class="admin-content">
    <h2 class="fw-bold mb-4">Customer Orders</h2>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            @if (Model.Count > 0)
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Order ID</th>
                                <th>Customer</th>
                                <th>Service</th>
                                <th>Amount</th>
                                <th>Payment</th>
                                <th>Status</th>
                                <th>Date</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model)
                            {
                                <tr>
                                    <td><strong>@order.OrderReference</strong></td>
                                    <td>
                                        @order.CompanyName<br>
                                        <small class="text-muted">@order.ContactName</small>
                                    </td>
                                    <td>@order.ServiceType - @order.PackageName</td>
                                    <td><strong>$@order.Amount.ToString("N2")</strong></td>
                                    <td><small>@order.PaymentMethod</small></td>
                                    <td>
                                        @if (order.PaymentStatus == "Paid")
                                        {
                                            <span class="badge bg-success">Paid</span>
                                        }
                                        else if (order.PaymentStatus == "Pending")
                                        {
                                            <span class="badge bg-warning">Pending</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Failed</span>
                                        }
                                    </td>
                                    <td>@order.OrderDate.ToString("MMM dd, yyyy")</td>
                                    <td>
                                        <a href="/Admin/OrderDetails/@order.Id" class="btn btn-sm btn-outline-primary">
                                            <i class="fas fa-eye"></i> View
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="fas fa-shopping-cart fa-4x text-muted mb-3"></i>
                    <h5 class="text-muted">No orders yet</h5>
                </div>
            }
        </div>
    </div>
</div>