@model List<CornerstoneDigital.Models.Testimonial>
@{
    ViewData["Title"] = "Manage Testimonials";
}

<style>
    .admin-sidebar {
        background: linear-gradient(135deg, #6B2E3E 0%, #4A1F2C 100%);
        min-height: 100vh;
        padding: 20px;
        position: fixed;
        width: 250px;
    }

        .admin-sidebar a {
            color: white;
            text-decoration: none;
            display: block;
            padding: 12px 15px;
            border-radius: 8px;
            margin-bottom: 5px;
        }

            .admin-sidebar a:hover, .admin-sidebar a.active {
                background: rgba(201, 169, 97, 0.3);
            }

    .admin-content {
        margin-left: 270px;
        padding: 30px;
    }
</style>

<div class="admin-sidebar">
    <div class="text-center mb-4">
        <h4 class="text-white fw-bold">CORNERSTONE</h4>
        <p class="text-white-50 small">Admin Panel</p>
    </div>
    <a href="/Admin"><i class="fas fa-tachometer-alt me-2"></i> Dashboard</a>
    <a href="/Admin/Projects"><i class="fas fa-project-diagram me-2"></i> Projects</a>
    <a href="/Admin/Packages"><i class="fas fa-box me-2"></i> Service Packages</a>
    <a href="/Admin/Orders"><i class="fas fa-shopping-cart me-2"></i> Orders</a>
    <a href="/Admin/Testimonials" class="active"><i class="fas fa-star me-2"></i> Testimonials</a>
    <hr style="border-color: rgba(255,255,255,0.3);">
    <a href="/"><i class="fas fa-globe me-2"></i> View Website</a>
</div>

<div class="admin-content">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">Client Testimonials</h2>
            <p class="text-muted">Manage customer reviews</p>
        </div>
        <a href="/Admin/CreateTestimonial" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>Add Testimonial
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-4">
        @foreach (var testimonial in Model)
        {
            <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                @for (int i = 0; i < testimonial.Rating; i++)
                                {
                                    <i class="fas fa-star text-warning"></i>
                                }
                            </div>
                            <div>
                                @if (testimonial.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </div>
                        </div>

                        <p class="fst-italic">"@testimonial.Review"</p>

                        <div class="mt-3">
                            <strong>@testimonial.ClientName</strong><br>
                            <small class="text-muted">@testimonial.Company</small>
                        </div>

                        <div class="mt-3">
                            <a href="/Admin/EditTestimonial/@testimonial.Id" class="btn btn-sm btn-outline-primary me-2">
                                <i class="fas fa-edit"></i> Edit
                            </a>
                            <a href="/Admin/DeleteTestimonial/@testimonial.Id" class="btn btn-sm btn-outline-danger"
                               onclick="return confirm('Delete this testimonial?')">
                                <i class="fas fa-trash"></i> Delete
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>