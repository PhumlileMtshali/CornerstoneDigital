@model List<CornerstoneDigital.Models.Project>
@{
    ViewData["Title"] = "Manage Projects";
}

<!-- Include Admin Sidebar (same as Dashboard) -->
<style>
    .admin-sidebar {
        background: linear-gradient(135deg, #6B2E3E 0%, #4A1F2C 100%);
        min-height: 100vh;
        padding: 20px;
        position: fixed;
        width: 250px;
    }

        .admin-sidebar a {
            color: white;
            text-decoration: none;
            display: block;
            padding: 12px 15px;
            border-radius: 8px;
            margin-bottom: 5px;
            transition: all 0.3s ease;
        }

            .admin-sidebar a:hover,
            .admin-sidebar a.active {
                background: rgba(201, 169, 97, 0.3);
            }

    .admin-content {
        margin-left: 270px;
        padding: 30px;
    }
</style>

<div class="admin-sidebar">
    <div class="text-center mb-4">
        <h4 class="text-white fw-bold">CORNERSTONE</h4>
        <p class="text-white-50 small">Admin Panel</p>
    </div>

    <a href="/Admin">
        <i class="fas fa-tachometer-alt me-2"></i> Dashboard
    </a>
    <a href="/Admin/Projects" class="active">
        <i class="fas fa-project-diagram me-2"></i> Projects
    </a>
    <a href="/Admin/Packages">
        <i class="fas fa-box me-2"></i> Service Packages
    </a>
    <a href="/Admin/Orders">
        <i class="fas fa-shopping-cart me-2"></i> Orders
    </a>
    <a href="/Admin/Testimonials">
        <i class="fas fa-star me-2"></i> Testimonials
    </a>
    <hr style="border-color: rgba(255,255,255,0.3);">
    <a href="/">
        <i class="fas fa-globe me-2"></i> View Website
    </a>
</div>

<div class="admin-content">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">Portfolio Projects</h2>
            <p class="text-muted">Manage your portfolio showcase</p>
        </div>
        <a href="/Admin/CreateProject" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>Add New Project
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            @if (Model.Count > 0)
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Title</th>
                                <th>Category</th>
                                <th>Client</th>
                                <th>Status</th>
                                <th>Created</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var project in Model)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <i class="fas fa-@project.ImageIcon fa-2x text-primary me-3"></i>
                                            <strong>@project.Title</strong>
                                        </div>
                                    </td>
                                    <td><span class="badge bg-primary">@project.Category</span></td>
                                    <td>@project.Client</td>
                                    <td>
                                        @if (project.IsActive)
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Inactive</span>
                                        }
                                    </td>
                                    <td>@project.CreatedDate.ToString("MMM dd, yyyy")</td>
                                    <td>
                                        <div class="btn-group" role="group">
                                            <a href="/Admin/EditProject/@project.Id" class="btn btn-sm btn-outline-primary">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <a href="/Admin/DeleteProject/@project.Id"
                                               class="btn btn-sm btn-outline-danger"
                                               onclick="return confirm('Are you sure you want to delete this project?')">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="fas fa-folder-open fa-4x text-muted mb-3"></i>
                    <h5 class="text-muted">No projects yet</h5>
                    <p class="text-muted mb-4">Start by adding your first portfolio project</p>
                    <a href="/Admin/CreateProject" class="btn btn-primary">
                        <i class="fas fa-plus me-2"></i>Create First Project
                    </a>
                </div>
            }
        </div>
    </div>
</div>