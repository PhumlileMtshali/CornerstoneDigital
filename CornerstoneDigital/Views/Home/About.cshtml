@{
    ViewData["Title"] = "About Us";
}

<!-- Page Header -->
<section class="page-header bg-primary text-white py-5">
    <div class="container text-center py-4">
        <h1 class="display-4 fw-bold mb-3">About Cornerstone Digital</h1>
        <p class="lead">Building your digital foundation with honesty and expertise</p>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb justify-content-center bg-transparent mb-0">
                <li class="breadcrumb-item"><a href="#" class="text-white">Home</a></li>
                <li class="breadcrumb-item text-white-50 active">About</li>
            </ol>
        </nav>
    </div>
</section>

<!-- Our Story -->
<section class="py-5">
    <div class="container py-4">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-4 mb-lg-0">
                <h2 class="display-5 fw-bold mb-4">Our Story</h2>
                <p class="lead text-muted mb-4">
                    We started Cornerstone Digital because we kept hearing the same story:
                    hardworking business owners getting scammed by fake developers.
                </p>
                <p class="mb-4">
                    As students, we understand what it's like to work with limited budgets.
                    As aspiring professionals, we refuse to be part of an industry that preys
                    on small businesses who are just trying to grow.
                </p>
                <p class="mb-4">
                    Our mission is simple: provide honest, affordable, professional digital
                    solutions to small businesses. No vanishing acts. No empty promises.
                    Just real students doing real work for real businesses.
                </p>
                <div class="alert alert-info border-0">
                    <i class="fas fa-quote-left me-2"></i>
                    <em>
                        "Every small business deserves a fighting chance in the digital world.
                        We're here to level the playing field."
                    </em>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="card border-0 shadow-lg">
                    <div class="card-body p-5">
                        <div class="row g-4 text-center">
                            <div class="col-6">
                                <div class="p-3">
                                    <i class="fas fa-handshake fa-3x text-primary mb-3"></i>
                                    <h4 class="fw-bold text-primary">150+</h4>
                                    <p class="text-muted mb-0">Successful Projects</p>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="p-3">
                                    <i class="fas fa-heart fa-3x text-primary mb-3"></i>
                                    <h4 class="fw-bold text-primary">98%</h4>
                                    <p class="text-muted mb-0">Client Satisfaction</p>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="p-3">
                                    <i class="fas fa-users fa-3x text-primary mb-3"></i>
                                    <h4 class="fw-bold text-primary">50+</h4>
                                    <p class="text-muted mb-0">Happy Clients</p>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="p-3">
                                    <i class="fas fa-trophy fa-3x text-primary mb-3"></i>
                                    <h4 class="fw-bold text-primary">Zero</h4>
                                    <p class="text-muted mb-0">Vanishing Acts</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Our Values -->
<section class="py-5 bg-light">
    <div class="container py-4">
        <div class="text-center mb-5">
            <h2 class="display-5 fw-bold mb-3">Our Values</h2>
            <p class="lead text-muted">What drives us every day</p>
        </div>

        <div class="row g-4">
            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body p-4 text-center">
                        <div class="mb-4">
                            <div class="icon-circle mx-auto">
                                <i class="fas fa-shield-alt fa-3x text-primary"></i>
                            </div>
                        </div>
                        <h4 class="fw-bold mb-3">Honesty First</h4>
                        <p class="text-muted">
                            We tell you exactly what we can deliver and when. No overpromising,
                            no excuses. Just straight talk and real timelines.
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body p-4 text-center">
                        <div class="mb-4">
                            <div class="icon-circle mx-auto">
                                <i class="fas fa-dollar-sign fa-3x text-primary"></i>
                            </div>
                        </div>
                        <h4 class="fw-bold mb-3">Fair Pricing</h4>
                        <p class="text-muted">
                            Quality doesn't have to break the bank. We offer transparent pricing
                            that makes professional digital services accessible to small businesses.
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body p-4 text-center">
                        <div class="mb-4">
                            <div class="icon-circle mx-auto">
                                <i class="fas fa-star fa-3x text-primary"></i>
                            </div>
                        </div>
                        <h4 class="fw-bold mb-3">Quality Work</h4>
                        <p class="text-muted">
                            Being affordable doesn't mean cutting corners. We deliver professional,
                            high-quality work that we're proud to put our names on.
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body p-4 text-center">
                        <div class="mb-4">
                            <div class="icon-circle mx-auto">
                                <i class="fas fa-comments fa-3x text-primary"></i>
                            </div>
                        </div>
                        <h4 class="fw-bold mb-3">Clear Communication</h4>
                        <p class="text-muted">
                            No tech jargon. No hiding behind emails. We explain everything in
                            plain English and stay in touch throughout your project.
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body p-4 text-center">
                        <div class="mb-4">
                            <div class="icon-circle mx-auto">
                                <i class="fas fa-user-check fa-3x text-primary"></i>
                            </div>
                        </div>
                        <h4 class="fw-bold mb-3">Accountability</h4>
                        <p class="text-muted">
                            We're local, reachable, and real people. You'll always know who you're
                            working with and how to contact us.
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body p-4 text-center">
                        <div class="mb-4">
                            <div class="icon-circle mx-auto">
                                <i class="fas fa-heart fa-3x text-primary"></i>
                            </div>
                        </div>
                        <h4 class="fw-bold mb-3">Your Success</h4>
                        <p class="text-muted">
                            We only succeed when you succeed. Your growth is our goal, and
                            we're invested in seeing your business thrive.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Why We're Different -->
<section class="py-5">
    <div class="container py-4">
        <div class="text-center mb-5">
            <h2 class="display-5 fw-bold mb-3">Why Choose Us?</h2>
            <p class="lead text-muted">What makes Cornerstone Digital different</p>
        </div>

        <div class="row g-4">
            <div class="col-lg-6">
                <div class="card border-0 bg-light h-100">
                    <div class="card-body p-4">
                        <h4 class="fw-bold mb-4"><i class="fas fa-times-circle text-danger me-2"></i>Other "Developers"</h4>
                        <ul class="list-unstyled">
                            <li class="mb-3 text-muted">
                                <i class="fas fa-times text-danger me-2"></i>
                                Take money upfront and disappear
                            </li>
                            <li class="mb-3 text-muted">
                                <i class="fas fa-times text-danger me-2"></i>
                                Deliver broken templates and call it "custom"
                            </li>
                            <li class="mb-3 text-muted">
                                <i class="fas fa-times text-danger me-2"></i>
                                Hide behind anonymous profiles
                            </li>
                            <li class="mb-3 text-muted">
                                <i class="fas fa-times text-danger me-2"></i>
                                Keep making excuses and asking for more money
                            </li>
                            <li class="mb-3 text-muted">
                                <i class="fas fa-times text-danger me-2"></i>
                                Ghost you after taking payment
                            </li>
                        </ul>
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="card border-primary border-3 h-100">
                    <div class="card-body p-4">
                        <h4 class="fw-bold mb-4"><i class="fas fa-check-circle text-success me-2"></i>Cornerstone Digital</h4>
                        <ul class="list-unstyled">
                            <li class="mb-3">
                                <i class="fas fa-check text-success me-2"></i>
                                <strong>Fair payment structure</strong> - tied to milestones, not upfront
                            </li>
                            <li class="mb-3">
                                <i class="fas fa-check text-success me-2"></i>
                                <strong>Custom built solutions</strong> - tailored to your needs
                            </li>
                            <li class="mb-3">
                                <i class="fas fa-check text-success me-2"></i>
                                <strong>Real, local people</strong> - with names, faces, and phones
                            </li>
                            <li class="mb-3">
                                <i class="fas fa-check text-success me-2"></i>
                                <strong>Transparent process</strong> - see your progress in real-time
                            </li>
                            <li class="mb-3">
                                <i class="fas fa-check text-success me-2"></i>
                                <strong>Ongoing support</strong> - we're here after launch too
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Our Process -->
<section class="py-5 bg-light">
    <div class="container py-4">
        <div class="text-center mb-5">
            <h2 class="display-5 fw-bold mb-3">How We Work</h2>
            <p class="lead text-muted">Simple, transparent process from start to finish</p>
        </div>

        <div class="row g-4">
            <div class="col-md-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body p-4 text-center">
                        <div class="step-number mb-3">1</div>
                        <h5 class="fw-bold mb-3">Discovery Call</h5>
                        <p class="text-muted small">
                            We discuss your needs, goals, and budget. No pressure, just conversation.
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body p-4 text-center">
                        <div class="step-number mb-3">2</div>
                        <h5 class="fw-bold mb-3">Proposal</h5>
                        <p class="text-muted small">
                            Clear quote with timeline, deliverables, and payment terms.
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body p-4 text-center">
                        <div class="step-number mb-3">3</div>
                        <h5 class="fw-bold mb-3">Build</h5>
                        <p class="text-muted small">
                            We create your project with regular updates and your feedback.
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body p-4 text-center">
                        <div class="step-number mb-3">4</div>
                        <h5 class="fw-bold mb-3">Launch</h5>
                        <p class="text-muted small">
                            We launch and train you. Plus ongoing support for peace of mind.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Meet the Team (Optional) -->
<section class="py-5">
    <div class="container py-4">
        <div class="text-center mb-5">
            <h2 class="display-5 fw-bold mb-3">Meet the Team</h2>
            <p class="lead text-muted">The real people behind Cornerstone Digital</p>
        </div>

        <div class="row g-4 justify-content-center">
            <div class="col-md-4 col-lg-3">
                <div class="card border-0 shadow-sm text-center">
                    <div class="card-body p-4">
                        <div class="team-avatar mb-3 mx-auto">
                            <i class="fas fa-user fa-4x text-primary"></i>
                        </div>
                        <h5 class="fw-bold mb-1">Team Member 1</h5>
                        <p class="text-muted small mb-3">Lead Developer</p>
                        <div class="social-links">
                            <a href="#" class="text-primary me-2"><i class="fab fa-linkedin"></i></a>
                            <a href="#" class="text-primary"><i class="fab fa-github"></i></a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-4 col-lg-3">
                <div class="card border-0 shadow-sm text-center">
                    <div class="card-body p-4">
                        <div class="team-avatar mb-3 mx-auto">
                            <i class="fas fa-user fa-4x text-primary"></i>
                        </div>
                        <h5 class="fw-bold mb-1">Team Member 2</h5>
                        <p class="text-muted small mb-3">Designer</p>
                        <div class="social-links">
                            <a href="#" class="text-primary me-2"><i class="fab fa-linkedin"></i></a>
                            <a href="#" class="text-primary"><i class="fab fa-behance"></i></a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-4 col-lg-3">
                <div class="card border-0 shadow-sm text-center">
                    <div class="card-body p-4">
                        <div class="team-avatar mb-3 mx-auto">
                            <i class="fas fa-user fa-4x text-primary"></i>
                        </div>
                        <h5 class="fw-bold mb-1">Team Member 3</h5>
                        <p class="text-muted small mb-3">Marketing Specialist</p>
                        <div class="social-links">
                            <a href="#" class="text-primary me-2"><i class="fab fa-linkedin"></i></a>
                            <a href="#" class="text-primary"><i class="fab fa-twitter"></i></a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .icon-circle {
        width: 100px;
        height: 100px;
        background: linear-gradient(135deg, rgba(107, 46, 62, 0.1) 0%, rgba(201, 169, 97, 0.1) 100%);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .step-number {
        width: 60px;
        height: 60px;
        background: linear-gradient(135deg, var(--primary-burgundy) 0%, var(--primary-maroon) 100%);
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        font-weight: bold;
        margin: 0 auto;
    }

    .team-avatar {
        width: 120px;
        height: 120px;
        background: linear-gradient(135deg, rgba(107, 46, 62, 0.1) 0%, rgba(201, 169, 97, 0.1) 100%);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }
</style>