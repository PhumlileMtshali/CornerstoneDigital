@{
    ViewData["Title"] = "Checkout";
    var service = ViewBag.Service;
    var package = ViewBag.Package;
    var companyName = ViewBag.CompanyName;
    var contactName = ViewBag.ContactName;
    var email = ViewBag.Email;
    var phone = ViewBag.Phone;

    // Get package details
    string packageName = "";
    string price = "";
    decimal amount = 0;

    if (service == "website")
    {
        if (package == "basic") { packageName = "Website Development - Basic"; price = "$499"; amount = 499; }
        else if (package == "standard") { packageName = "Website Development - Standard"; price = "$999"; amount = 999; }
        else if (package == "premium") { packageName = "Website Development - Premium"; price = "$1,999"; amount = 1999; }
    }
    else if (service == "ecommerce")
    {
        if (package == "starter") { packageName = "E-commerce - Starter"; price = "$799"; amount = 799; }
        else if (package == "professional") { packageName = "E-commerce - Professional"; price = "$1,499"; amount = 1499; }
    }
    else if (service == "branding")
    {
        if (package == "basic") { packageName = "Brand Identity - Basic"; price = "$299"; amount = 299; }
        else if (package == "standard") { packageName = "Brand Identity - Standard"; price = "$599"; amount = 599; }
        else if (package == "premium") { packageName = "Brand Identity - Premium"; price = "$1,199"; amount = 1199; }
    }
    else if (service == "seo")
    {
        if (package == "local") { packageName = "SEO - Local"; price = "$399/month"; amount = 399; }
        else if (package == "advanced") { packageName = "SEO - Advanced"; price = "$699/month"; amount = 699; }
    }

    decimal taxAmount = amount * 0.15m; // 15% VAT for SA
    decimal totalAmount = amount + taxAmount;
}

<style>
    .checkout-container {
        max-width: 1200px;
        margin: 0 auto;
    }

    .order-summary-card {
        background: linear-gradient(135deg, #6B2E3E 0%, #4A1F2C 100%);
        color: white;
        border-radius: 15px;
        padding: 30px;
        position: sticky;
        top: 100px;
    }

    .payment-method-card {
        border: 2px solid #e0e0e0;
        border-radius: 12px;
        padding: 20px;
        cursor: pointer;
        transition: all 0.3s ease;
        margin-bottom: 15px;
    }

        .payment-method-card:hover {
            border-color: #C9A961;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(107, 46, 62, 0.2);
        }

        .payment-method-card.active {
            border-color: #6B2E3E;
            background-color: #f8f9fa;
        }

        .payment-method-card input[type="radio"] {
            accent-color: #6B2E3E;
        }

    .payment-logo {
        height: 40px;
        object-fit: contain;
    }

    .secure-badge {
        background: #28a745;
        color: white;
        padding: 5px 15px;
        border-radius: 20px;
        font-size: 12px;
        display: inline-block;
    }

    .payment-btn {
        background: linear-gradient(135deg, #6B2E3E 0%, #4A1F2C 100%);
        border: none;
        padding: 15px;
        font-size: 18px;
        font-weight: 600;
        width: 100%;
        transition: all 0.3s ease;
    }

        .payment-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(107, 46, 62, 0.3);
        }

    .summary-line {
        display: flex;
        justify-content: space-between;
        padding: 10px 0;
        border-bottom: 1px solid rgba(255,255,255,0.2);
    }

        .summary-line.total {
            font-size: 1.3rem;
            font-weight: 700;
            border-bottom: none;
            padding-top: 20px;
            color: #C9A961;
        }
</style>

<!-- Page Header -->
<section class="bg-primary text-white py-5">
    <div class="container text-center py-4">
        <h1 class="display-4 fw-bold mb-3">Secure Checkout</h1>
        <p class="lead">Complete your order securely</p>
        <div class="d-flex justify-content-center gap-3 mt-3">
            <span class="secure-badge"><i class="fas fa-lock me-2"></i>256-bit SSL Encrypted</span>
            <span class="secure-badge"><i class="fas fa-shield-alt me-2"></i>PCI Compliant</span>
        </div>
    </div>
</section>

<!-- Checkout Content -->
<section class="py-5">
    <div class="container checkout-container">
        <div class="row">
            <!-- Left Column - Payment Methods -->
            <div class="col-lg-8 mb-4">
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body p-4">
                        <h4 class="fw-bold mb-3"><i class="fas fa-user me-2 text-primary"></i>Order Information</h4>
                        <div class="row">
                            <div class="col-md-6 mb-2">
                                <strong>Company:</strong> @companyName
                            </div>
                            <div class="col-md-6 mb-2">
                                <strong>Contact:</strong> @contactName
                            </div>
                            <div class="col-md-6 mb-2">
                                <strong>Email:</strong> @email
                            </div>
                            <div class="col-md-6 mb-2">
                                <strong>Phone:</strong> @phone
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">
                        <h4 class="fw-bold mb-4"><i class="fas fa-credit-card me-2 text-primary"></i>Select Payment Method</h4>

                        <form id="paymentForm" asp-controller="Home" asp-action="ProcessPayment" method="post">
                            <input type="hidden" name="service" value="@service" />
                            <input type="hidden" name="package" value="@package" />
                            <input type="hidden" name="amount" value="@totalAmount" />
                            <input type="hidden" name="companyName" value="@companyName" />
                            <input type="hidden" name="email" value="@email" />

                            <!-- South African Payment Options -->
                            <h5 class="fw-bold mb-3 text-primary">🇿🇦 South African Payment Methods</h5>

                            <!-- PayFast -->
                            <div class="payment-method-card" onclick="selectPayment('payfast', event)">
                                <div class="d-flex align-items-center justify-content-between">
                                    <div class="d-flex align-items-center">
                                        <input type="radio" name="paymentMethod" id="payfast" value="payfast" class="me-3">
                                        <div>
                                            <h6 class="mb-1 fw-bold">PayFast</h6>
                                            <small class="text-muted">Instant EFT, Credit/Debit Cards, Bitcoin</small>
                                        </div>
                                    </div>
                                    <div class="text-end">
                                        <span class="badge bg-success">Most Popular in SA</span>
                                    </div>
                                </div>
                            </div>

                            <!-- Yoco -->
                            <div class="payment-method-card" onclick="selectPayment('yoco', event)">
                                <div class="d-flex align-items-center justify-content-between">
                                    <div class="d-flex align-items-center">
                                        <input type="radio" name="paymentMethod" id="yoco" value="yoco" class="me-3">
                                        <div>
                                            <h6 class="mb-1 fw-bold">Yoco</h6>
                                            <small class="text-muted">All major credit and debit cards</small>
                                        </div>
                                    </div>
                                    <div>
                                        <i class="fas fa-credit-card fa-2x text-primary"></i>
                                    </div>
                                </div>
                            </div>

                            <!-- Bank Transfer -->
                            <div class="payment-method-card" onclick="selectPayment('eft', event)">
                                <div class="d-flex align-items-center justify-content-between">
                                    <div class="d-flex align-items-center">
                                        <input type="radio" name="paymentMethod" id="eft" value="eft" class="me-3">
                                        <div>
                                            <h6 class="mb-1 fw-bold">Direct Bank Transfer (EFT)</h6>
                                            <small class="text-muted">Manual transfer to our bank account</small>
                                        </div>
                                    </div>
                                    <div>
                                        <i class="fas fa-university fa-2x text-primary"></i>
                                    </div>
                                </div>
                            </div>

                            <hr class="my-4">

                            <!-- International Payment Options -->
                            <h5 class="fw-bold mb-3 text-primary">🌍 International Payment Methods</h5>

                            <!-- Stripe -->
                            <div class="payment-method-card" onclick="selectPayment('stripe', event)">
                                <div class="d-flex align-items-center justify-content-between">
                                    <div class="d-flex align-items-center">
                                        <input type="radio" name="paymentMethod" id="stripe" value="stripe" class="me-3">
                                        <div>
                                            <h6 class="mb-1 fw-bold">Credit/Debit Card (Stripe)</h6>
                                            <small class="text-muted">Visa, Mastercard, Amex - All currencies accepted</small>
                                        </div>
                                    </div>
                                    <div>
                                        <i class="fab fa-cc-stripe fa-2x text-primary"></i>
                                    </div>
                                </div>
                            </div>

                            <!-- PayPal -->
                            <div class="payment-method-card" onclick="selectPayment('paypal', event)">
                                <div class="d-flex align-items-center justify-content-between">
                                    <div class="d-flex align-items-center">
                                        <input type="radio" name="paymentMethod" id="paypal" value="paypal" class="me-3">
                                        <div>
                                            <h6 class="mb-1 fw-bold">PayPal</h6>
                                            <small class="text-muted">Pay with your PayPal account or card</small>
                                        </div>
                                    </div>
                                    <div>
                                        <i class="fab fa-paypal fa-2x text-primary"></i>
                                    </div>
                                </div>
                            </div>

                            <!-- Wire Transfer -->
                            <div class="payment-method-card" onclick="selectPayment('wire', event)">
                                <div class="d-flex align-items-center justify-content-between">
                                    <div class="d-flex align-items-center">
                                        <input type="radio" name="paymentMethod" id="wire" value="wire" class="me-3">
                                        <div>
                                            <h6 class="mb-1 fw-bold">International Wire Transfer</h6>
                                            <small class="text-muted">SWIFT transfer (3-5 business days)</small>
                                        </div>
                                    </div>
                                    <div>
                                        <i class="fas fa-globe fa-2x text-primary"></i>
                                    </div>
                                </div>
                            </div>

                            <!-- Security Notice -->
                            <div class="alert alert-info mt-4">
                                <i class="fas fa-shield-alt me-2"></i>
                                <strong>Your payment is secure:</strong> All transactions are encrypted with 256-bit SSL security.
                                We never store your payment information.
                            </div>

                            <!-- Terms & Conditions -->
                            <div class="form-check mt-4">
                                <input class="form-check-input" type="checkbox" id="termsAccept" required>
                                <label class="form-check-label" for="termsAccept">
                                    I agree to the <a asp-controller="Home" asp-action="Terms" target="_blank">Terms & Conditions</a>
                                    and <a asp-controller="Home" asp-action="Privacy" target="_blank">Privacy Policy</a>
                                </label>
                            </div>

                            <!-- Submit Button -->
                            <button type="submit" class="btn btn-primary payment-btn mt-4" id="paymentBtn" disabled>
                                <i class="fas fa-lock me-2"></i>Proceed to Secure Payment
                            </button>
                        </form>
                    </div>
                </div>

                <!-- Trust Badges -->
                <div class="row mt-4 text-center">
                    <div class="col-4">
                        <i class="fas fa-lock fa-3x text-success mb-2"></i>
                        <p class="small mb-0"><strong>SSL Secure</strong></p>
                    </div>
                    <div class="col-4">
                        <i class="fas fa-shield-alt fa-3x text-success mb-2"></i>
                        <p class="small mb-0"><strong>PCI Compliant</strong></p>
                    </div>
                    <div class="col-4">
                        <i class="fas fa-check-circle fa-3x text-success mb-2"></i>
                        <p class="small mb-0"><strong>Money Back Guarantee</strong></p>
                    </div>
                </div>
            </div>

            <!-- Right Column - Order Summary -->
            <div class="col-lg-4">
                <div class="order-summary-card">
                    <h4 class="fw-bold mb-4"><i class="fas fa-shopping-cart me-2"></i>Order Summary</h4>

                    <div class="mb-4">
                        <h6 class="text-white-50 mb-2">Package Selected:</h6>
                        <h5 class="fw-bold">@packageName</h5>
                    </div>

                    <hr style="border-color: rgba(255,255,255,0.3);">

                    <div class="summary-line">
                        <span>Subtotal:</span>
                        <span>$@amount.ToString("N2")</span>
                    </div>

                    <div class="summary-line">
                        <span>VAT (15%):</span>
                        <span>$@taxAmount.ToString("N2")</span>
                    </div>

                    <div class="summary-line total">
                        <span>Total:</span>
                        <span>$@totalAmount.ToString("N2")</span>
                    </div>

                    <div class="mt-4 p-3" style="background: rgba(255,255,255,0.1); border-radius: 10px;">
                        <h6 class="mb-2"><i class="fas fa-gift me-2"></i>What You Get:</h6>
                        <ul class="small mb-0 ps-3">
                            <li>Professional service delivery</li>
                            <li>Dedicated project manager</li>
                            <li>Regular progress updates</li>
                            <li>Post-launch support</li>
                            <li>100% satisfaction guarantee</li>
                        </ul>
                    </div>

                    <div class="mt-4 text-center">
                        <small class="text-white-50">
                            <i class="fas fa-question-circle me-2"></i>
                            Need help? <a href="mailto:support@cornerstonedigital.com" class="text-white">Contact Support</a>
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    function selectPayment(method, clickEvent) {
        // Remove active class from all cards
        document.querySelectorAll('.payment-method-card').forEach(card => {
            card.classList.remove('active');
        });

        // Add active class to selected card
        clickEvent.currentTarget.classList.add('active');

        // Check the radio button
        document.getElementById(method).checked = true;

        // Enable payment button if terms accepted
        checkFormValidity();
    }

    // Enable submit button when payment method selected and terms accepted
    document.getElementById('termsAccept').addEventListener('change', checkFormValidity);
    document.querySelectorAll('input[name="paymentMethod"]').forEach(radio => {
        radio.addEventListener('change', checkFormValidity);
    });

    function checkFormValidity() {
        const paymentSelected = document.querySelector('input[name="paymentMethod"]:checked');
        const termsAccepted = document.getElementById('termsAccept').checked;
        const paymentBtn = document.getElementById('paymentBtn');

        if (paymentSelected && termsAccepted) {
            paymentBtn.disabled = false;
        } else {
            paymentBtn.disabled = true;
        }
    }

    // Prevent multiple submissions
    document.getElementById('paymentForm').addEventListener('submit', function(e) {
        const btn = document.getElementById('paymentBtn');
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Processing...';
    });
</script>