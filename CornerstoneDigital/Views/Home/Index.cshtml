        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="cta-section py-5">
    <div class="container py-5 text-center text-white">
        <h2 class="display-5 fw-bold mb-4">Ready to Build Your Digital Foundation?</h2>
        <p class="lead mb-4">Let's discuss how we can help your business grow online</p>
        <div class="d-flex gap-3 justify-content-center flex-wrap">
            <a class="btn btn-light btn-lg px-5" asp-controller="Home" asp-action="Quote">
                Get a Free Quote
            </a>
            <a class="btn btn-outline-light btn-lg px-5" asp-controller="Home" asp-action="Contact">
                Contact Us
            </a>
        </div>
    </div>
</section>