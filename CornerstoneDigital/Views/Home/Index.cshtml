                        </p>
                        <div class="d-flex align-items-center">
                            <div class="avatar-placeholder me-3">
                                <i class="fas fa-user fa-2x text-primary"></i>
                            </div>
                            <div>
                                <h6 class="mb-0 fw-bold">Emily Rodriguez</h6>
                                <small class="text-muted">Green Earth Co</small>
                            </div>
                        </div>
                    </div>
