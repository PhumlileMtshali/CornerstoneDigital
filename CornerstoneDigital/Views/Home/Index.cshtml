@{
    ViewData["Title"] = "Home";
}

<!-- Hero Section -->
<section class="hero-section">
    <div class="container">
        <div class="row align-items-center min-vh-75">
            <div class="col-lg-6">
                <h1 class="display-3 fw-bold text-white mb-4">
                    Build Your Digital Foundation
                </h1>
                <p class="lead text-white-50 mb-4">
                    Professional web solutions for ambitious small businesses.
                    Affordable, reliable, and results-driven.
                </p>
                <div class="d-flex gap-3 flex-wrap">
                    <a asp-controller="Services" asp-action="Index" class="btn btn-light btn-lg px-5">
                        <i class="fas fa-rocket me-2"></i>View Services
                    </a>
                    <a asp-controller="Home" asp-action="Portfolio" class="btn btn-outline-light btn-lg px-5">
                        See Our Work
                    </a>
                </div>

                <!-- Stats -->
                <div class="row mt-5 text-white">
                    <div class="col-4">
                        <h3 class="fw-bold">150+</h3>
                        <p class="small">Projects</p>
                    </div>
                    <div class="col-4">
                        <h3 class="fw-bold">98%</h3>
                        <p class="small">Satisfaction</p>
                    </div>
                    <div class="col-4">
                        <h3 class="fw-bold">50+</h3>
                        <p class="small">Clients</p>
                    </div>
                </div>
            </div>

            <div class="col-lg-6 d-none d-lg-block">
                <img src="~/images/hero-illustration.jpg" alt="Digital Services" class="img-fluid">
            </div>
        </div>
    </div>
</section>

<!-- Services Overview -->
<section class="py-5 bg-light">
    <div class="container py-5">
        <div class="text-center mb-5">
            <h2 class="display-5 fw-bold mb-3">Our Services</h2>
            <p class="lead text-muted">Comprehensive digital solutions for your business</p>
        </div>

        <div class="row g-4">
            <div class="col-md-6 col-lg-3">
                <div class="card h-100 border-0 shadow-sm service-card">
                    <div class="card-body text-center p-4">
                        <div class="service-icon mb-3">
                            <i class="fas fa-laptop-code fa-3x text-primary"></i>
                        </div>
                        <h5 class="card-title fw-bold">Website Development</h5>
                        <p class="card-text text-muted">Custom, responsive websites tailored to your business needs</p>
                        <a asp-controller="Services" asp-action="Index" class="btn btn-outline-primary btn-sm">
                            Learn More <i class="fas fa-arrow-right ms-2"></i>
                        </a>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-3">
                <div class="card h-100 border-0 shadow-sm service-card">
                    <div class="card-body text-center p-4">
                        <div class="service-icon mb-3">
                            <i class="fas fa-shopping-cart fa-3x text-primary"></i>
                        </div>
                        <h5 class="card-title fw-bold">E-commerce Setup</h5>
                        <p class="card-text text-muted">Complete online store solutions with payment integration</p>
                        <a asp-controller="Services" asp-action="Index" class="btn btn-outline-primary btn-sm">
                            Learn More <i class="fas fa-arrow-right ms-2"></i>
                        </a>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-3">
                <div class="card h-100 border-0 shadow-sm service-card">
                    <div class="card-body text-center p-4">
                        <div class="service-icon mb-3">
                            <i class="fas fa-palette fa-3x text-primary"></i>
                        </div>
                        <h5 class="card-title fw-bold">Brand Identity</h5>
                        <p class="card-text text-muted">Logo design and complete brand identity packages</p>
                        <a asp-controller="Services" asp-action="Index" class="btn btn-outline-primary btn-sm">
                            Learn More <i class="fas fa-arrow-right ms-2"></i>
                        </a>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-3">
                <div class="card h-100 border-0 shadow-sm service-card">
                    <div class="card-body text-center p-4">
                        <div class="service-icon mb-3">
                            <i class="fas fa-chart-line fa-3x text-primary"></i>
                        </div>
                        <h5 class="card-title fw-bold">SEO Optimization</h5>
                        <p class="card-text text-muted">Improve your search rankings and online visibility</p>
                        <a asp-controller="Services" asp-action="Index" class="btn btn-outline-primary btn-sm">
                            Learn More <i class="fas fa-arrow-right ms-2"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Why Choose Us -->
<section class="py-5">
    <div class="container py-5">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-4 mb-lg-0">
                <h2 class="display-5 fw-bold mb-4">Why Choose Cornerstone Digital?</h2>
                <p class="lead text-muted mb-4">
                    We're not just another web agency. We're students who understand tight budgets
                    and business owners who've been let down by empty promises.
                </p>

                <div class="feature-list">
                    <div class="d-flex mb-3">
                        <div class="flex-shrink-0">
                            <i class="fas fa-check-circle fa-2x text-success"></i>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h5 class="fw-bold">Transparent Pricing</h5>
                            <p class="text-muted">No hidden fees. Clear packages with everything included.</p>
                        </div>
                    </div>

                    <div class="d-flex mb-3">
                        <div class="flex-shrink-0">
                            <i class="fas fa-check-circle fa-2x text-success"></i>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h5 class="fw-bold">Real People, Real Service</h5>
                            <p class="text-muted">Local students you can trust. No vanishing acts.</p>
                        </div>
                    </div>

                    <div class="d-flex mb-3">
                        <div class="flex-shrink-0">
                            <i class="fas fa-check-circle fa-2x text-success"></i>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h5 class="fw-bold">Quality Guaranteed</h5>
                            <p class="text-muted">We don't deliver until you're 100% satisfied.</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <img src="~/images/why-choose-us.jpg" alt="Why Choose Us" class="img-fluid rounded shadow">
            </div>
        </div>
    </div>
</section>

