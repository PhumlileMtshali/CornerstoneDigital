@{
    ViewData["Title"] = "Confirm Your Package";
    var service = ViewBag.Service;
    var package = ViewBag.Package;

    // Get package name for display
    string packageName = "";
    string price = "";

    if (service == "website")
    {
        if (package == "basic") { packageName = "Website Development - Basic"; price = "$499"; }
        else if (package == "standard") { packageName = "Website Development - Standard"; price = "$999"; }
        else if (package == "premium") { packageName = "Website Development - Premium"; price = "$1,999"; }
    }
    else if (service == "ecommerce")
    {
        if (package == "starter") { packageName = "E-commerce - Starter"; price = "$799"; }
        else if (package == "professional") { packageName = "E-commerce - Professional"; price = "$1,499"; }
    }
    else if (service == "branding")
    {
        if (package == "basic") { packageName = "Brand Identity - Basic"; price = "$299"; }
        else if (package == "standard") { packageName = "Brand Identity - Standard"; price = "$599"; }
        else if (package == "premium") { packageName = "Brand Identity - Premium"; price = "$1,199"; }
    }
    else if (service == "seo")
    {
        if (package == "local") { packageName = "SEO - Local"; price = "$399/month"; }
        else if (package == "advanced") { packageName = "SEO - Advanced"; price = "$699/month"; }
    }
}

<style>
    .confirmation-card {
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(107, 46, 62, 0.15);
    }

    .package-summary {
        background: linear-gradient(135deg, #6B2E3E 0%, #4A1F2C 100%);
        color: white;
        padding: 30px;
        border-radius: 15px;
        margin-bottom: 30px;
    }

    .form-control:focus {
        border-color: #C9A961;
        box-shadow: 0 0 0 0.2rem rgba(201, 169, 97, 0.25);
    }

    .submit-btn {
        background: linear-gradient(135deg, #6B2E3E 0%, #4A1F2C 100%);
        border: none;
        padding: 15px 50px;
        font-size: 18px;
        font-weight: 600;
        transition: all 0.3s ease;
    }

        .submit-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(107, 46, 62, 0.3);
        }
</style>

<!-- Page Header -->
<section class="bg-primary text-white py-5">
    <div class="container text-center py-4">
        <h1 class="display-4 fw-bold mb-3">Confirm Your Selection</h1>
        <p class="lead">Just one more step to get started!</p>
    </div>
</section>

<!-- Confirmation Form -->
<section class="py-5">
    <div class="container py-4">
        <div class="row justify-content-center">
            <div class="col-lg-8">

                <!-- Package Summary -->
                <div class="package-summary">
                    <div class="row align-items-center">
                        <div class="col-md-8">
                            <h4 class="fw-bold mb-2">Selected Package:</h4>
                            <h3 class="mb-0">@packageName</h3>
                        </div>
                        <div class="col-md-4 text-md-end">
                            <h2 class="fw-bold mb-0" style="color: #C9A961;">@price</h2>
                        </div>
                    </div>
                </div>

                <!-- Confirmation Form -->
                <div class="card confirmation-card border-0">
                    <div class="card-body p-5">
                        <h4 class="fw-bold mb-4">Tell Us About Your Project</h4>
                        <p class="text-muted mb-4">
                            Please provide your information so we can get started on your project.
                            We'll contact you within 24 hours to discuss next steps.
                        </p>

                        <form asp-controller="Home" asp-action="SubmitConfirmation" method="post">
                            <input type="hidden" name="service" value="@service" />
                            <input type="hidden" name="package" value="@package" />

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label for="companyName" class="form-label fw-bold">Company Name *</label>
                                    <input type="text" class="form-control" id="companyName" name="companyName" required placeholder="Your company name">
                                </div>

                                <div class="col-md-6 mb-3">
                                    <label for="contactName" class="form-label fw-bold">Contact Name *</label>
                                    <input type="text" class="form-control" id="contactName" name="contactName" required placeholder="Your full name">
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label for="email" class="form-label fw-bold">Email Address *</label>
                                    <input type="email" class="form-control" id="email" name="email" required placeholder="your@email.com">
                                </div>

                                <div class="col-md-6 mb-3">
                                    <label for="phone" class="form-label fw-bold">Phone Number *</label>
                                    <input type="tel" class="form-control" id="phone" name="phone" required placeholder="+27 XX XXX XXXX">
                                </div>
                            </div>

                            <div class="mb-4">
                                <label for="projectDetails" class="form-label fw-bold">Project Details *</label>
                                <textarea class="form-control" id="projectDetails" name="projectDetails" rows="5" required placeholder="Tell us about your project, goals, timeline, and any specific requirements..."></textarea>
                                <small class="text-muted">The more details you provide, the better we can serve you!</small>
                            </div>

                            <div class="alert alert-info">
                                <i class="fas fa-info-circle me-2"></i>
                                <strong>What happens next?</strong>
                                <ul class="mb-0 mt-2">
                                    <li>You'll receive a confirmation email immediately</li>
                                    <li>Our team will review your requirements</li>
                                    <li>We'll contact you within 24 hours to schedule a consultation</li>
                                    <li>We'll create a detailed project plan and timeline</li>
                                </ul>
                            </div>

                            <div class="d-grid gap-3">
                                <button type="submit" class="btn btn-primary submit-btn">
                                    <i class="fas fa-paper-plane me-2"></i>Confirm & Submit
                                </button>
                                <a asp-controller="Home" asp-action="PackageDetails" asp-route-service="@service" asp-route-package="@package" class="btn btn-outline-primary">
                                    <i class="fas fa-arrow-left me-2"></i>Back to Package Details
                                </a>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Trust Indicators -->
                <div class="row mt-4">
                    <div class="col-md-4 text-center mb-3">
                        <i class="fas fa-shield-alt fa-3x text-primary mb-2"></i>
                        <p class="small fw-bold mb-0">Secure & Confidential</p>
                    </div>
                    <div class="col-md-4 text-center mb-3">
                        <i class="fas fa-clock fa-3x text-primary mb-2"></i>
                        <p class="small fw-bold mb-0">24-Hour Response</p>
                    </div>
                    <div class="col-md-4 text-center mb-3">
                        <i class="fas fa-handshake fa-3x text-primary mb-2"></i>
                        <p class="small fw-bold mb-0">No Obligation Consultation</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>