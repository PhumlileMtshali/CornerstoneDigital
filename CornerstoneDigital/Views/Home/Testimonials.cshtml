<style>
    .testimonial-image-placeholder {
        height: 300px;
        background: linear-gradient(135deg, var(--primary-maroon) 0%, var(--primary-burgundy) 100%);
    }

    .testimonial-avatar {
        width: 70px;
        height: 70px;
        background: linear-gradient(135deg, rgba(107, 46, 62, 0.1) 0%, rgba(201, 169, 97, 0.1) 100%);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .testimonial-avatar-sm {
        width: 50px;
        height: 50px;
        background: linear-gradient(135deg, rgba(107, 46, 62, 0.1) 0%, rgba(201, 169, 97, 0.1) 100%);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .testimonial-card {
        transition: all 0.3s ease;
    }

        .testimonial-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.15) !important;
        }

    .video-placeholder {
        height: 250px;
        background: linear-gradient(135deg, var(--primary-maroon) 0%, var(--primary-burgundy) 100%);
        cursor: pointer;
        transition: all 0.3s ease;
    }

        .video-placeholder:hover {
            opacity: 0.9;
        }

    .stat-card {
        padding: 2rem;
    }
</style>
