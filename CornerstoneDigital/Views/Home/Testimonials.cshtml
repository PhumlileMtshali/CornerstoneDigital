                    <i class="fas fa-star fa-3x text-warning mb-3"></i>
                    <h2 class="fw-bold text-primary mb-2">4.9/5</h2>
                    <p class="text-muted mb-0">Average Rating</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-card">
                    <i class="fas fa-users fa-3x text-primary mb-3"></i>
                    <h2 class="fw-bold text-primary mb-2">50+</h2>
                    <p class="text-muted mb-0">Happy Clients</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-card">
                    <i class="fas fa-thumbs-up fa-3x text-primary mb-3"></i>
                    <h2 class="fw-bold text-primary mb-2">98%</h2>
                    <p class="text-muted mb-0">Would Recommend</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-card">
                    <i class="fas fa-redo fa-3x text-primary mb-3"></i>
