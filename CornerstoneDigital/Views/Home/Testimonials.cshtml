</section>

<!-- Featured Testimonials -->
<section class="py-5">
    <div class="container py-4">
        <div class="text-center mb-5">
            <h2 class="display-6 fw-bold mb-3">Featured Success Stories</h2>
            <p class="lead text-muted">See how we've helped businesses transform their online presence</p>
        </div>

        <!-- Featured Testimonial 1 -->
        <div class="row align-items-center mb-5 pb-5 border-bottom">
            <div class="col-lg-5 mb-4 mb-lg-0">
                <div class="testimonial-image-placeholder bg-gradient rounded shadow p-5 text-center">
                    <i class="fas fa-wrench fa-5x text-white"></i>
                </div>
            </div>
            <div class="col-lg-7">
                <div class="mb-3">
                    <i class="fas fa-star text-warning"></i>
                    <i class="fas fa-star text-warning"></i>
                    <i class="fas fa-star text-warning"></i>
                    <i class="fas fa-star text-warning"></i>
                    <i class="fas fa-star text-warning"></i>
                </div>
                <h3 class="fw-bold mb-3">"They Restored My Faith After Two Scams"</h3>
                <p class="lead text-muted mb-4">
                    "I was scammed twice by 'developers' who took my money and disappeared. I was
                    ready to give up on having a website entirely. Then I found Cornerstone Digital.
                    They were transparent from day one, showed me progress every week, and delivered
                    exactly what they promised. Within a month of launching, my online bookings went
                    from zero to 40% of my business."
                </p>
                <div class="d-flex align-items-center">
                    <div class="testimonial-avatar me-3">
                        <i class="fas fa-user fa-2x text-primary"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold mb-0">David Martinez</h5>
                        <p class="text-muted mb-0">Owner, Martinez Auto Repair</p>
                        <small class="text-muted">Houston, TX</small>
                    </div>
                </div>
                <div class="mt-4">
                    <span class="badge bg-primary me-2">Website Development</span>
                    <span class="badge bg-success">Online Booking System</span>
                </div>
            </div>
        </div>

        <!-- Featured Testimonial 2 -->
        <div class="row align-items-center mb-5 pb-5 border-bottom flex-lg-row-reverse">
            <div class="col-lg-5 mb-4 mb-lg-0">
                <div class="testimonial-image-placeholder bg-gradient rounded shadow p-5 text-center">
                    <i class="fas fa-shopping-bag fa-5x text-white"></i>
                </div>
            </div>
            <div class="col-lg-7">
                <div class="mb-3">
                    <i class="fas fa-star text-warning"></i>
                    <i class="fas fa-star text-warning"></i>
                    <i class="fas fa-star text-warning"></i>
                    <i class="fas fa-star text-warning"></i>
                    <i class="fas fa-star text-warning"></i>
                </div>
                <h3 class="fw-bold mb-3">"From Craft Fairs to Nationwide Shipping"</h3>
                <p class="lead text-muted mb-4">
                    "I was selling my handmade jewelry at local craft fairs, making maybe $500 a month.
                    I wanted an online store but every platform I tried was too complicated. Cornerstone
                    Digital built me a beautiful e-commerce site that's easy to manage. First month:
                    $3,200 in sales. Six months later: I quit my day job and now ship nationwide.
                    Best investment I ever made."
                </p>
                <div class="d-flex align-items-center">
                    <div class="testimonial-avatar me-3">
                        <i class="fas fa-user fa-2x text-primary"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold mb-0">Sarah Chen</h5>
                        <p class="text-muted mb-0">Founder, Chen Handmade Jewelry</p>
                        <small class="text-muted">Portland, OR</small>
                    </div>
                </div>
                <div class="mt-4">
                    <span class="badge bg-success me-2">E-commerce Store</span>
                    <span class="badge bg-primary">Payment Integration</span>
                    <span class="badge bg-warning text-dark">SEO</span>
                </div>
            </div>
        </div>

        <!-- Featured Testimonial 3 -->
        <div class="row align-items-center mb-5">
            <div class="col-lg-5 mb-4 mb-lg-0">
                <div class="testimonial-image-placeholder bg-gradient rounded shadow p-5 text-center">
                    <i class="fas fa-utensils fa-5x text-white"></i>
                </div>
            </div>
            <div class="col-lg-7">
                <div class="mb-3">
                    <i class="fas fa-star text-warning"></i>
                    <i class="fas fa-star text-warning"></i>
                    <i class="fas fa-star text-warning"></i>
                    <i class="fas fa-star text-warning"></i>
                    <i class="fas fa-star text-warning"></i>
                </div>
                <h3 class="fw-bold mb-3">"Our Revenue Increased 45% in 3 Months"</h3>
                <p class="lead text-muted mb-4">
                    "We had an outdated website that looked terrible on phones and didn't show up on Google.
                    Cornerstone Digital gave us a complete rebrand - new logo, beautiful website, and local
