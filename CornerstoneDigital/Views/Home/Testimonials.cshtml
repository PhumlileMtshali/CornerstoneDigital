                    <span class="badge bg-primary me-2">Website Redesign</span>
                    <span class="badge bg-warning text-dark me-2">Brand Identity</span>
                    <span class="badge bg-info text-dark">Local SEO</span>
                </div>
            </div>
        </div>
    </div>
</section>

