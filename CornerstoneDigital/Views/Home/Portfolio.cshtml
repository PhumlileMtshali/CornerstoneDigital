@{
    ViewData["Title"] = "Our Portfolio";
}

<!-- Page Header -->
<section class="page-header bg-primary text-white py-5">
    <div class="container text-center py-4">
        <h1 class="display-4 fw-bold mb-3">Our Work</h1>
        <p class="lead">Real projects, real results for real businesses</p>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb justify-content-center bg-transparent mb-0">
                <li class="breadcrumb-item"><a href="#" class="text-white">Home</a></li>
                <li class="breadcrumb-item text-white-50 active">Portfolio</li>
            </ol>
        </nav>
    </div>
</section>

<!-- Portfolio Stats -->
<section class="py-5 bg-light">
    <div class="container">
        <div class="row text-center g-4">
            <div class="col-md-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body py-4">
                        <i class="fas fa-project-diagram fa-3x text-primary mb-3"></i>
                        <h2 class="fw-bold text-primary mb-2">150+</h2>
                        <p class="text-muted mb-0">Projects Completed</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body py-4">
                        <i class="fas fa-smile fa-3x text-primary mb-3"></i>
                        <h2 class="fw-bold text-primary mb-2">98%</h2>
                        <p class="text-muted mb-0">Client Satisfaction</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body py-4">
                        <i class="fas fa-award fa-3x text-primary mb-3"></i>
                        <h2 class="fw-bold text-primary mb-2">25+</h2>
                        <p class="text-muted mb-0">Industries Served</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body py-4">
                        <i class="fas fa-clock fa-3x text-primary mb-3"></i>
                        <h2 class="fw-bold text-primary mb-2">2-4</h2>
                        <p class="text-muted mb-0">Weeks Average</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Filter Buttons -->
<section class="py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="display-5 fw-bold mb-3">Featured Projects</h2>
            <p class="lead text-muted mb-4">Browse our recent work across different industries</p>

            <div class="btn-group flex-wrap justify-content-center" role="group">
                <button type="button" class="btn btn-outline-primary active" data-filter="all">All Projects</button>
                <button type="button" class="btn btn-outline-primary" data-filter="website">Websites</button>
                <button type="button" class="btn btn-outline-primary" data-filter="ecommerce">E-commerce</button>
                <button type="button" class="btn btn-outline-primary" data-filter="branding">Branding</button>
            </div>
        </div>

        <!-- Portfolio Grid -->
        <div class="row g-4">
            <!-- Project 1 -->
            <div class="col-md-6 col-lg-4 portfolio-item" data-category="website">
                <div class="card border-0 shadow-sm h-100 portfolio-card">
                    <div class="position-relative overflow-hidden">
                        <div class="portfolio-image bg-gradient p-5 text-center">
                            <i class="fas fa-laptop-code fa-5x text-white"></i>
                        </div>
                        <div class="portfolio-overlay">
                            <a asp-controller="Home" asp-action="ProjectDetails" asp-route-id="tech-startup" class="btn btn-light btn-sm">
                                <i class="fas fa-eye me-2"></i>View Project
                            </a>
                        </div>
                    </div>
                    <div class="card-body">
                        <span class="badge bg-primary mb-2">Website</span>
                        <h5 class="card-title fw-bold">Tech Startup Landing Page</h5>
                        <p class="card-text text-muted">Modern, conversion-focused landing page for a SaaS startup</p>
                        <hr>
                        <div class="d-flex justify-content-between align-items-center">
                            <small class="text-muted"><i class="fas fa-chart-line me-1"></i> 300% lead increase</small>
                            <small class="text-muted"><i class="fas fa-calendar me-1"></i> 3 weeks</small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Project 2 -->
            <div class="col-md-6 col-lg-4 portfolio-item" data-category="ecommerce">
                <div class="card border-0 shadow-sm h-100 portfolio-card">
                    <div class="position-relative overflow-hidden">
                        <div class="portfolio-image bg-gradient p-5 text-center">
                            <i class="fas fa-shopping-bag fa-5x text-white"></i>
                        </div>
                        <div class="portfolio-overlay">
                            <a asp-controller="Home" asp-action="ProjectDetails" asp-route-id="fashion-store" class="btn btn-light btn-sm">
                                <i class="fas fa-eye me-2"></i>View Project
                            </a>
                        </div>
                    </div>
                    <div class="card-body">
                        <span class="badge bg-success mb-2">E-commerce</span>
                        <h5 class="card-title fw-bold">Boutique Fashion Store</h5>
                        <p class="card-text text-muted">Complete online store with 200+ products and payment integration</p>
                        <hr>
                        <div class="d-flex justify-content-between align-items-center">
                            <small class="text-muted"><i class="fas fa-dollar-sign me-1"></i> $50K first month</small>
                            <small class="text-muted"><i class="fas fa-calendar me-1"></i> 6 weeks</small>
                        </div>
                    </div>
                </div>
            </div>

