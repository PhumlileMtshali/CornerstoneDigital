                            <small class="text-muted"><i class="fas fa-calendar me-1"></i> 5 weeks</small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Project 5 -->
            <div class="col-md-6 col-lg-4 portfolio-item" data-category="ecommerce">
                <div class="card border-0 shadow-sm h-100 portfolio-card">
                    <div class="position-relative overflow-hidden">
                        <div class="portfolio-image bg-gradient p-5 text-center">
                            <i class="fas fa-gem fa-5x text-white"></i>
                        </div>
                        <div class="portfolio-overlay">
                            <a asp-controller="Home" asp-action="ProjectDetails" asp-route-id="jewelry-store" class="btn btn-light btn-sm">
