<!-- CTA Section -->
<section class="cta-section py-5">
    <div class="container py-5 text-center text-white">
        <h2 class="display-5 fw-bold mb-4">Ready to Be Our Next Success Story?</h2>
        <p class="lead mb-4">Let's create something amazing together</p>
        <div class="d-flex gap-3 justify-content-center flex-wrap">
            <a href="#" class="btn btn-light btn-lg px-5">
                <i class="fas fa-rocket me-2"></i>Start Your Project
            </a>
            <a href="#" class="btn btn-outline-light btn-lg px-5">
                <i class="fas fa-calendar me-2"></i>Schedule Consultation
            </a>
        </div>
    </div>
</section>

<style>
    .portfolio-image {
        height: 250px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, var(--primary-maroon) 0%, var(--primary-burgundy) 100%);
    }

    .portfolio-card {
        transition: all 0.3s ease;
    }

        .portfolio-card:hover {
            transform: translateY(-10px);
        }

    .portfolio-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(107, 46, 62, 0.9);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: all 0.3s ease;
    }

    .portfolio-card:hover .portfolio-overlay {
        opacity: 1;
    }

    .bg-gradient {
        background: linear-gradient(135deg, var(--primary-maroon) 0%, var(--primary-burgundy) 50%, var(--burgundy-light) 100%);
    }
</style>