@page
@model CornerstoneDigital.Areas.Identity.Pages.Account.RegisterModel

@{
    ViewData["Title"] = "Register";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Cornerstone Digital</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            min-height: 100vh;
            display: flex;
            overflow: auto;
        }

        .register-wrapper {
            display: flex;
            width: 100%;
            min-height: 100vh;
        }

        /* Left Side - Benefits Section */
        .benefits-section {
            flex: 1;
            background: linear-gradient(135deg, #4A1F2C 0%, #6B2E3E 50%, #8B4458 100%);
            padding: 60px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            color: white;
            position: relative;
            overflow: hidden;
        }

            .benefits-section::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                background: radial-gradient(circle at 20% 50%, rgba(201, 169, 97, 0.1) 0%, transparent 50%);
                pointer-events: none;
            }

        .benefits-content {
            position: relative;
            z-index: 1;
            max-width: 500px;
            animation: slideInLeft 0.8s ease-out;
        }

        .benefits-title {
            font-size: 42px;
            font-weight: 700;
            margin-bottom: 20px;
            line-height: 1.2;
        }

        .benefits-subtitle {
            font-size: 18px;
            margin-bottom: 40px;
            opacity: 0.95;
        }

        .benefit-item {
            display: flex;
            align-items: flex-start;
            margin-bottom: 30px;
            animation: fadeIn 0.8s ease-out forwards;
            opacity: 0;
        }

            .benefit-item:nth-child(1) {
                animation-delay: 0.2s;
            }

            .benefit-item:nth-child(2) {
                animation-delay: 0.4s;
            }

            .benefit-item:nth-child(3) {
                animation-delay: 0.6s;
            }

            .benefit-item:nth-child(4) {
                animation-delay: 0.8s;
            }

        .benefit-icon {
            width: 50px;
            height: 50px;
            background: rgba(201, 169, 97, 0.2);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            margin-right: 20px;
            flex-shrink: 0;
        }

        .benefit-text h3 {
            font-size: 18px;
            margin-bottom: 8px;
            color: #C9A961;
        }

        .benefit-text p {
            font-size: 14px;
            opacity: 0.9;
            line-height: 1.5;
        }

        /* Right Side - Form Section */
        .form-section {
            flex: 1;
            background: white;
            padding: 60px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            animation: slideInRight 0.8s ease-out;
            overflow-y: auto;
            max-height: 100vh;
        }

        .form-container {
            width: 100%;
            max-width: 450px;
            padding: 20px 0;
        }

        .logo {
            text-align: center;
            margin-bottom: 40px;
        }

            .logo h1 {
                font-size: 32px;
                color: #6B2E3E;
                font-weight: 700;
                margin-bottom: 10px;
            }

            .logo p {
                color: #666;
                font-size: 14px;
            }

        .form-header {
            text-align: center;
            margin-bottom: 5px;
        }

            .form-header h2 {
                font-size: 28px;
                color: #333;
                margin-bottom: 10px;
            }

            .form-header p {
                color: #666;
                font-size: 14px;
            }

        .form-group {
            margin-bottom: 25px;
        }

            .form-group label {
                display: block;
                color: #333;
                font-weight: 600;
                margin-bottom: 8px;
                font-size: 14px;
            }

        .form-control {
            width: 100%;
            padding: 14px 16px;
            border: 2px solid #e0e0e0;
            border-radius: 8px;
            font-size: 15px;
            transition: all 0.3s ease;
            background: #fafafa;
        }

            .form-control:focus {
                outline: none;
                border-color: #C9A961;
                background: white;
                box-shadow: 0 0 0 3px rgba(201, 169, 97, 0.1);
            }

        .btn-register {
            width: 100%;
            padding: 14px;
            background: linear-gradient(135deg, #6B2E3E 0%, #4A1F2C 100%);
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(107, 46, 62, 0.3);
        }

            .btn-register:hover {
                transform: translateY(-2px);
                box-shadow: 0 6px 20px rgba(107, 46, 62, 0.4);
                background: linear-gradient(135deg, #4A1F2C 0%, #6B2E3E 100%);
            }

            .btn-register:active {
                transform: translateY(0);
            }

        .form-footer {
            text-align: center;
            margin-top: 25px;
        }

            .form-footer p {
                margin: 12px 0;
                font-size: 14px;
            }

            .form-footer a {
                color: #6B2E3E;
                text-decoration: none;
                font-weight: 600;
                transition: color 0.3s ease;
            }

                .form-footer a:hover {
                    color: #C9A961;
                    text-decoration: underline;
                }

        .divider {
            text-align: center;
            margin: 20px 0;
            color: #999;
            font-size: 13px;
        }

        .validation-summary-errors {
            background: #fee;
            border: 1px solid #fcc;
            border-radius: 8px;
            padding: 15px;
            margin-bottom: 20px;
        }

            .validation-summary-errors ul {
                margin: 0;
                padding-left: 20px;
                list-style: disc;
            }

            .validation-summary-errors li {
                color: #c33;
                font-size: 14px;
            }

        .text-danger {
            color: #c33;
            font-size: 12px;
            margin-top: 5px;
            display: block;
        }

        /* Animations */
        @@keyframes slideInLeft {
            from {
                opacity: 0;
                transform: translateX(-50px);
            }

            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        @@keyframes slideInRight {
            from {
                opacity: 0;
                transform: translateX(50px);
            }

            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Mobile Responsive */
        @@media (max-width: 968px) {
            .benefits-section {
                display: none;
            }

            .form-section {
                padding: 40px 20px;
            }

            .form-container {
                max-width: 100%;
            }

            .logo h1 {
                font-size: 28px;
            }

            .form-header h2 {
                font-size: 24px;
            }
        }

        @@media (max-width: 480px) {
            .form-section {
                padding: 30px 15px;
            }

            .form-control {
                padding: 12px 14px;
            }

            .btn-register {
                padding: 12px;
                font-size: 15px;
            }
        }
    </style>
</head>
<body>
    <div class="register-wrapper">
        <!-- Left Side - Benefits -->
        <div class="benefits-section">
            <div class="benefits-content">
                <h1 class="benefits-title">Join Cornerstone Digital Today</h1>
                <p class="benefits-subtitle">Start your journey to digital excellence</p>

                <div class="benefit-item">
                    <div class="benefit-icon">🎨</div>
                    <div class="benefit-text">
                        <h3>Professional Services</h3>
                        <p>Access world-class web design and development</p>
                    </div>
                </div>

                <div class="benefit-item">
                    <div class="benefit-icon">📊</div>
                    <div class="benefit-text">
                        <h3>Project Management</h3>
                        <p>Streamlined workflows and transparent tracking</p>
                    </div>
                </div>

                <div class="benefit-item">
                    <div class="benefit-icon">🔒</div>
                    <div class="benefit-text">
                        <h3>Secure & Reliable</h3>
                        <p>Enterprise-grade security for your peace of mind</p>
                    </div>
                </div>

                <div class="benefit-item">
                    <div class="benefit-icon">🌟</div>
                    <div class="benefit-text">
                        <h3>24/7 Support</h3>
                        <p>Round-the-clock assistance whenever you need it</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Side - Form -->
        <div class="form-section">
            <div class="form-container">
                <div class="logo">
                    <a href="/" style="text-decoration: none; display: flex; align-items: center; justify-content: center; gap: 15px; margin-bottom: 10px;">
                        <img src="~/Images/Logo.jpeg" alt="Cornerstone Digital Logo" style="height: 60px; width: auto; border-radius: 8px;" />
                        <div style="text-align: left;">
                            <h1 style="margin: 0; color: #6B2E3E;">CORNERSTONE</h1>
                            <p style="margin: 0; color: #666; font-size: 14px;">Digital Solutions</p>
                        </div>
                    </a>
                    <a href="/" style="display: inline-block; margin-top: 10px; color: #6B2E3E; text-decoration: none; font-size: 14px; font-weight: 600; transition: color 0.3s ease;">
                        ← Back to Home
                    </a>
                </div>

                <div class="form-header">
                    <h2>Create Account</h2>
                    <p>Fill in your details to get started</p>
                </div>

                <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                    <div asp-validation-summary="ModelOnly" class="validation-summary-errors" role="alert"></div>

                    <div class="form-group">
                        <label asp-for="Input.Email">Email Address</label>
                        <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="Enter your email" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Input.Password">Password</label>
                        <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Create a strong password" />
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Input.ConfirmPassword">Confirm Password</label>
                        <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Re-enter your password" />
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                    </div>

                    <button id="registerSubmit" type="submit" class="btn-register">Create Account</button>

                    <div class="form-footer">
                        <div class="divider">───────  or  ───────</div>
                        <p>
                            Already have an account? <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl">Sign in here</a>
                        </p>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>